<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Notebook · AI 研究助手</title>
<style>
:root{--bg:#fff;--side-bg:#f9f9f9;--text:#1a1a1a;--text2:#6b6b6b;--text3:#9a9a9a;--accent:#2563eb;--accent-light:#eff6ff;--border:#eaeaea;--hover:#f3f3f3;--radius:8px;--radius-lg:16px;--font:-apple-system,BlinkMacSystemFont,"SF Pro Text","PingFang SC","Microsoft YaHei",sans-serif}
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent}
html,body{height:100%;width:100%}
body{font-family:var(--font);color:var(--text);background:var(--bg);display:flex;overflow:hidden}

.sidebar{display:none;position:fixed;z-index:100;left:0;top:0;bottom:0;width:280px;background:var(--side-bg);flex-direction:column;overflow-y:auto;-webkit-overflow-scrolling:touch;box-shadow:2px 0 16px rgba(0,0,0,.1);padding-top:env(safe-area-inset-top);padding-bottom:env(safe-area-inset-bottom)}
.sidebar.open{display:flex}
@media(min-width:769px){
    .sidebar{display:flex;position:relative;z-index:1;width:260px;box-shadow:none;border-right:1px solid var(--border);flex-shrink:0;padding-top:0;padding-bottom:0}
}

.sidebar-h{padding:20px 16px 8px;font-size:13px;font-weight:600;letter-spacing:-.2px}
.nav{overflow-y:auto;padding:0 8px}
.nav-item{display:flex;align-items:center;gap:8px;padding:8px 10px;border-radius:6px;font-size:13px;cursor:pointer;color:var(--text2);margin:1px 0;transition:background .1s;touch-action:manipulation;min-height:36px}
.nav-item:hover{background:var(--hover);color:var(--text)}
.nav-item.sel{background:#eef2ff;color:var(--accent);font-weight:500}
.nav-item .count{font-size:10px;color:var(--text3);margin-left:auto}
.up-zone{margin:8px;padding:12px;border:1.5px dashed var(--border);border-radius:var(--radius);cursor:pointer;text-align:center;font-size:12px;color:var(--text3);transition:.15s;flex-shrink:0;touch-action:manipulation;min-height:44px;display:flex;align-items:center;justify-content:center}
.up-zone:hover{border-color:var(--accent);color:var(--accent);background:var(--accent-light)}
.up-zone input{display:none}

.main{flex:1;display:flex;flex-direction:column;min-width:0;overflow:hidden}
.header-bar{display:flex;align-items:center;padding:8px 12px;border-bottom:1px solid var(--border);flex-shrink:0;min-height:48px}

.tabs{display:flex;padding:0;border:none;flex-shrink:0}
.tab{padding:10px 16px;font-size:14px;color:var(--text2);cursor:pointer;border-bottom:2px solid transparent;transition:.15s;font-weight:500;touch-action:manipulation;min-height:40px;display:flex;align-items:center}
.tab:hover{color:var(--text)}
.tab.active{color:var(--accent);border-bottom-color:var(--accent)}

.chat-body{flex:1;overflow-y:auto;display:flex;flex-direction:column;-webkit-overflow-scrolling:touch}
.chat-msgs{flex:1;overflow-y:auto;padding:16px;max-width:720px;margin:0 auto;width:100%}
@media(min-width:769px){.chat-msgs{padding:24px 32px}}

.empty{display:flex;flex-direction:column;align-items:center;justify-content:center;height:100%;text-align:center}
.empty-icon{font-size:40px;margin-bottom:12px;opacity:.6}
.empty h2{font-size:17px;font-weight:600;margin-bottom:4px}
.empty p{font-size:13px;color:var(--text3)}

.msg{margin-bottom:16px}
.msg.user{display:flex;justify-content:flex-end}
.msg.user .bubble{background:#f0f4ff;padding:10px 16px;border-radius:var(--radius-lg) 4px var(--radius-lg) var(--radius-lg);font-size:14px;line-height:1.5;max-width:85%}
.msg.assistant .bubble{padding:4px 0;font-size:14px;line-height:1.7}
.msg .sources{margin-top:6px;display:flex;gap:4px;flex-wrap:wrap}
.msg .source{font-size:11px;color:var(--text3);background:var(--hover);padding:2px 8px;border-radius:10px}

.input-bar{padding:12px 16px;border-top:1px solid var(--border);flex-shrink:0;background:var(--bg)}
@media(min-width:769px){.input-bar{padding:12px 32px}}
.input-row{display:flex;gap:8px;align-items:center;max-width:720px;margin:0 auto}
.input-row textarea{flex:1;border:1.5px solid var(--border);border-radius:var(--radius-lg);padding:10px 14px;font-size:16px;font-family:var(--font);resize:none;outline:none;min-height:44px;line-height:1.4;transition:border-color .15s}
.input-row textarea:focus{border-color:var(--accent)}
.input-row button{background:var(--accent);color:#fff;border:none;padding:10px 20px;border-radius:var(--radius);font-size:14px;font-weight:600;cursor:pointer;flex-shrink:0;touch-action:manipulation;min-height:44px;min-width:60px}

.pod-body{display:none;flex:1;overflow-y:auto;padding:16px;max-width:720px;margin:0 auto;width:100%}
@media(min-width:769px){.pod-body{padding:24px 32px}}
.pod-form{display:none;gap:8px;padding:12px 16px;border-top:1px solid var(--border);flex-shrink:0;background:var(--bg)}
@media(min-width:769px){.pod-form{padding:12px 32px}}
.pod-form select,.pod-form input{flex:1;border:1.5px solid var(--border);border-radius:var(--radius-lg);padding:10px 14px;font-size:14px;font-family:var(--font);outline:none;min-height:40px}
.pod-form button{background:var(--accent);color:#fff;border:none;padding:10px 20px;border-radius:var(--radius);font-size:14px;font-weight:600;cursor:pointer;flex-shrink:0;touch-action:manipulation;min-height:40px}

.script{font-size:14px;line-height:1.9}
.script .sp{display:flex;gap:8px;margin:12px 0}
.script .sp .nm{font-weight:600;font-size:12px;color:var(--text3);min-width:50px;padding-top:2px}
.script .sp .tx{flex:1;background:var(--side-bg);padding:10px 14px;border-radius:var(--radius);line-height:1.6}

.hamburger{display:flex;align-items:center;justify-content:center;min-width:44px;min-height:44px;cursor:pointer;font-size:22px;color:var(--text2);border:none;background:none;border-radius:8px;touch-action:manipulation;padding:0}
.hamburger:active{background:var(--hover)}
@media(min-width:769px){.hamburger{display:none}}

#overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.2);z-index:99}

.modal-bg{display:none;position:fixed;inset:0;background:rgba(0,0,0,.3);z-index:200;align-items:center;justify-content:center}
.modal-bg.open{display:flex}
.modal{background:#fff;border-radius:12px;box-shadow:0 8px 40px rgba(0,0,0,.12);width:94%;max-width:640px;max-height:85vh;display:flex;flex-direction:column}
.modal-h{padding:16px 20px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:8px}
.modal-h h2{font-size:15px;flex:1}
.modal-close{cursor:pointer;font-size:20px;color:var(--text3);border:none;background:none;padding:4px;touch-action:manipulation;min-width:40px;min-height:40px}
.modal-b{flex:1;overflow-y:auto;padding:20px;font-size:13px;line-height:1.7}
.modal-tabs{display:flex;gap:0;border-bottom:1px solid var(--border);margin-bottom:16px}
.modal-tab{padding:8px 16px;font-size:13px;cursor:pointer;color:var(--text3);border-bottom:2px solid transparent;touch-action:manipulation;min-height:36px}
.modal-tab.active{color:var(--accent);border-bottom-color:var(--accent);font-weight:500}
.modal-panel{display:none}
.modal-panel.active{display:block}

.mm-node{margin-left:20px;position:relative;padding:2px 0}
.mm-node:before{content:'';position:absolute;left:-14px;top:0;bottom:0;width:1px;background:var(--border)}
.mm-node:last-child:before{height:10px}
.mm-label{padding:2px 8px;background:var(--accent-light);border-radius:4px;display:inline-block;font-size:12px;position:relative;margin:2px 0}
.mm-label:before{content:'';position:absolute;left:-14px;top:50%;width:14px;height:1px;background:var(--border)}
.mm-root>.mm-label{background:var(--accent);color:#fff;font-size:13px;padding:4px 12px;font-weight:600}
.mm-root:before{display:none}
.mm-root>.mm-label:before{display:none}

.toast{position:fixed;bottom:24px;left:50%;transform:translateX(-50%);background:#1a1a1a;color:#fff;padding:10px 24px;border-radius:20px;font-size:13px;z-index:300;opacity:0;transition:opacity .3s;pointer-events:none}
.toast.show{opacity:1}

.side-ft{padding:8px;flex-shrink:0;display:flex;gap:4px}
.side-ft input{flex:1;border:1px solid var(--border);border-radius:6px;padding:8px 10px;font-size:14px;outline:none;min-height:40px}
.side-ft button{background:var(--accent);color:#fff;border:none;padding:8px 14px;border-radius:6px;font-size:13px;cursor:pointer;touch-action:manipulation;min-height:40px}

.source-view{flex:1;display:flex;flex-direction:column;min-width:0;overflow:hidden}
.source-chunk{padding:10px 0;border-bottom:1px solid var(--border);font-size:14px;line-height:1.7;color:var(--text)}
.source-chunk:last-child{border-bottom:none}
.chunk-idx{display:inline-block;background:var(--accent-light);color:var(--accent);border-radius:3px;padding:1px 6px;font-size:11px;font-weight:600;margin-right:8px;vertical-align:middle}
.cite{display:inline-block;background:#eff6ff;color:#2563eb;border-radius:3px;padding:0 4px;font-size:11px;font-weight:600;cursor:pointer;margin:0 1px;vertical-align:super;line-height:1;transition:background .15s}
.cite:hover{background:#dbeafe}
.cite-popup{position:fixed;z-index:300;background:white;border:1px solid #e5e7eb;border-radius:12px;box-shadow:0 10px 40px rgba(0,0,0,.15);padding:16px;max-width:380px;font-size:13px;animation:cite-in .15s ease}
@keyframes cite-in{from{opacity:0;transform:translateY(4px)}to{opacity:1;transform:translateY(0)}}
.cite-popup .ctitle{font-weight:600;margin-bottom:8px;color:#2563eb}
.cite-popup .ctext{color:#4b5563;line-height:1.6;margin-bottom:12px;font-style:italic;background:#f9fafb;padding:8px 12px;border-radius:6px}
.cite-popup .cactions{display:flex;gap:8px}
.cite-popup .btn{font-size:12px;padding:6px 14px;border-radius:6px;border:1px solid #d1d5db;background:white;cursor:pointer}
.cite-popup .btn.primary{background:#2563eb;color:white;border-color:#2563eb}
.multi-doc-hint{font-size:11px;color:var(--text3);margin-top:6px;padding:4px 8px;background:#f0fdf4;border-radius:4px;display:inline-block}

body.dark{--bg:#111827;--side-bg:#1f2937;--text:#f1f5f9;--text2:#94a3b8;--text3:#64748b;--border:#334155;--hover:#1e293b;--accent-light:#1e3a5f}
body.dark .cite{background:#1e3a5f;color:#93c5fd}
body.dark .cite:hover{background:#1e40af}
body.dark .cite-popup{background:#1f2937;border-color:#334155;color:#e2e8f0}
body.dark .cite-popup .ctext{background:#111827;color:#cbd5e1}
body.dark .source-chunk{color:#e2e8f0}
body.dark .multi-doc-hint{background:#064e3b}
.dark-toggle{background:none;border:1px solid var(--border);border-radius:20px;padding:4px 10px;cursor:pointer;font-size:16px;line-height:1;transition:all .2s;margin-right:6px;min-width:36px}
.dark-toggle:hover{background:var(--hover)}
.stream-cursor{animation:blink 1s step-end infinite;color:var(--accent)}
@keyframes blink{50%{opacity:0}}
.suggest-chips{display:flex;flex-wrap:wrap;gap:6px;margin-top:12px;justify-content:center}
.suggest-chip{background:var(--accent-light);color:var(--accent);border:1px solid transparent;border-radius:16px;padding:6px 14px;font-size:12px;cursor:pointer;transition:all .15s;max-width:280px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.suggest-chip:hover{background:var(--accent);color:white;border-color:var(--accent)}
.clear-chat-btn{background:none;border:1px solid var(--border);border-radius:4px;padding:2px 8px;font-size:11px;cursor:pointer;color:var(--text3);margin-left:8px}
.clear-chat-btn:hover{color:#e53e3e;border-color:#e53e3e}
</style>
<script src="/static/marked.min.js?v=2"></script>
</head>
<body>

<div style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.15);z-index:9" id="overlay" data-action="closeSidebar"></div>

<aside class="sidebar" id="sidebar">
  <div style="padding:16px;font-size:15px;font-weight:700;display:flex;align-items:center;gap:6px">
    <span style="width:8px;height:8px;background:var(--accent);border-radius:50%"></span>Notebook
  </div>
  <div class="up-zone" data-action="triggerUpload">📤 上传文档<input type="file" id="fu" accept=".txt,.md,.pdf,.docx,.csv,.json" multiple></div>
  <div class="sidebar-h">分类</div>
  <nav class="nav" id="fn"></nav>
  <div class="sidebar-h">文档</div>
  <nav class="nav" id="dn" style="font-size:12px"></nav>
  <div class="side-ft">
    <input placeholder="新建分类" id="nfn" style="flex:1;border:1px solid var(--border);border-radius:6px;padding:6px 10px;font-size:12px;outline:none">
    <button data-action="createFolder" style="background:var(--accent);color:#fff;border:none;padding:6px 12px;border-radius:6px;font-size:12px;cursor:pointer">+</button>
  </div>
</aside>

<main class="main">
  <div class="header-bar">
    <button class="hamburger" data-action="toggleSidebar">☰</button>
    <button class="dark-toggle" id="dt" onclick="toggleDark()" title="切换深色模式">🌙</button><div class="tabs" style="border:none;padding:0">
      <div class="tab active" data-action="switchTab" data-tab="chat">💬 问答</div>
      <div class="tab" data-action="switchTab" data-tab="pod">🎙️ 播客</div>
      <div class="tab" data-action="switchTab" data-tab="source">📄 原文</div>
    </div>
    <span style="margin-left:auto;font-size:12px;color:var(--text3)" id="fb">全部文档</span><button class="clear-chat-btn" onclick="clearChat()" title="清空对话">清空</button>
    <button id="kb" data-action="openKnowledge" style="display:none;font-size:12px;background:none;border:1px solid var(--border);padding:3px 10px;border-radius:4px;cursor:pointer;color:var(--accent);margin-left:8px">📊</button>
  </div>

  <div class="chat-body" id="cv">
    <div class="chat-msgs" id="cm">
      <div class="empty" id="ce"><div class="empty-icon">📖</div><h2>上传文档，开始探索</h2><p>支持 PDF、DOCX、TXT、Markdown 等格式</p></div>
    </div>
    <div class="input-bar">
      <div class="input-row">
        <textarea id="qi" placeholder="向文档提问…" rows="1"></textarea>
        <button data-action="ask">发送</button>
      </div>
    </div>
  </div>

  <div class="pod-body" id="pv"><div class="empty"><div class="empty-icon">🎙️</div><h2>AI 双人播客</h2><p>基于文档生成对话式播客脚本</p></div></div>
  <div class="pod-form" id="pf">
    <select id="pdoc"><option value="">全部文档</option></select>
    <input id="ptopic" placeholder="主题（可选）">
    <button data-action="genPodcast">生成</button>
  </div>
  <div class="source-view" id="sv" style="display:none">
    <div style="padding:0 12px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:8px;min-height:44px">
      <select id="srcDoc" onchange="loadSource(this.value)" style="flex:1;padding:6px;border:1px solid var(--border);border-radius:4px;font-size:13px"><option value="">选择文档…</option></select>
    </div>
    <div class="chat-body" style="display:flex;overflow-y:auto;padding:16px" id="sc">
      <div class="empty"><div class="empty-icon">📄</div><h2>选择文档查看原文</h2><p>可逐段对照，追踪引用出处</p></div>
    </div>
  </div>
</main>

<div class="modal-bg" id="mbg" data-action="closeModalBg">
  <div class="modal"><div class="modal-h"><h2 id="mtitle">📊 知识梳理</h2><button class="modal-close" data-action="closeModal">✕</button></div>
  <div class="modal-b" id="mbody">
    <div class="modal-tabs"><div class="modal-tab active" data-action="switchKm" data-km="summary">知识总结</div><div class="modal-tab" data-action="switchKm" data-km="mindmap">思维导图</div><div class="modal-tab" data-action="switchKm" data-km="learning">学习路径</div></div>
    <div class="modal-panel active" id="kms"></div><div class="modal-panel" id="kmm"></div><div class="modal-panel" id="kml"></div>
  </div></div>
</div>

<div class="toast" id="toast"></div>

<script>
var API='',af='',ad='',cv='chat',hist=[],folders=[],docs=[],tt;

function g(id){return document.getElementById(id)}
function toast(m,d){clearTimeout(tt);var e=g('toast');e.textContent=m;e.classList.add('show');tt=setTimeout(function(){e.classList.remove('show')},d||2500)}
async function api(url,opt){var r=await fetch(API+url,opt||{});if(!r.ok)throw new Error('HTTP '+r.status);return r.json()}
function esc(s){return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')}
function getFn(id){if(!id||id==='uncategorized')return id==='uncategorized'?'未分类':'全部文档';var f=folders.find(function(x){return x.id===id});return f?f.name:id}

// ====== EVENT DELEGATION ======
document.addEventListener('DOMContentLoaded',function(){
  document.addEventListener('click',function(e){
    var el=e.target;
    while(el&&el!==document.body){
      var a=el.getAttribute('data-action');
      if(a){
        if(a==='toggleSidebar')toggleSidebar();
        else if(a==='closeSidebar')closeSidebar();
        else if(a==='triggerUpload')g('fu').click();
        else if(a==='ask')ask();
        else if(a==='openKnowledge')openKnowledge();
        else if(a==='closeModal')closeModal();
        else if(a==='closeModalBg'){if(e.target===el)closeModal();}
        else if(a==='createFolder')createFolder();
        else if(a==='genPodcast')genPodcast();
        else if(a==='switchTab')switchTab(el.getAttribute('data-tab'));
        else if(a==='switchKm')switchKm(el.getAttribute('data-km'));
        else if(a==='sf')sf(el.getAttribute('data-id'));
        else if(a==='sd')sd(el.getAttribute('data-id'));
        else if(a==='delDoc'){e.stopPropagation();delDoc(el.getAttribute('data-id'));}
        return;
      }
      el=el.parentElement;
    }
  });

  g('fu').addEventListener('change',function(){upload(this)});
  g('qi').addEventListener('keydown',function(e){if(e.key==='Enter'&&!e.shiftKey){e.preventDefault();ask()}});
  g('nfn').addEventListener('keydown',function(e){if(e.key==='Enter')createFolder()});

  loadAll();
});

// ====== SIDEBAR ======
function toggleSidebar(){var s=g('sidebar'),o=g('overlay');s.classList.toggle('open');o.style.display=s.classList.contains('open')?'block':'none'}
function closeSidebar(){g('sidebar').classList.remove('open');g('overlay').style.display='none'}

function switchTab(v){cv=v;document.querySelectorAll('.tab').forEach(function(t){t.classList.toggle('active',t.getAttribute('data-tab')===v)});g('cv').style.display=v==='chat'?'flex':'none';document.querySelector('.input-bar').style.display=v==='chat'?'flex':'none';g('pv').style.display=v==='pod'?'flex':'none';g('pf').style.display=v==='pod'?'flex':'none';g('sv').style.display=v==='source'?'flex':'none';if(v==='pod')updatePodSelect();if(v==='source')initSourcePanel()}

// ====== DATA ======
async function loadAll(){
  g('fn').innerHTML='<div style="padding:6px 10px;color:var(--text3);font-size:12px">加载中…</div>';
  g('dn').innerHTML='<div style="padding:6px 10px;color:var(--text3);font-size:12px">加载中…</div>';
  try{var f=await api('/api/folders');folders=f.folders||[];var d=await api('/api/docs'+(af?'?folder_id='+af:''));docs=d.documents||[];renderSidebar();suggestQuestions()}
  catch(e){g('fn').innerHTML='<div style="padding:6px 10px;color:#e53e3e;font-size:12px">❌ '+e.message+'</div>';g('dn').innerHTML=''}
}

function renderSidebar(){
  var h=ni('','全部文档','📂',af==='');h+=ni('uncategorized','未分类','📄',af==='uncategorized');
  folders.forEach(function(f){h+=ni(f.id,f.name,'📁',af===f.id)});g('fn').innerHTML=h;
  var d='';docs.forEach(function(dc){d+=di(dc.id,dc.title,ad===dc.id)});
  g('dn').innerHTML=d||'<div style="padding:6px 10px;font-size:11px;color:var(--text3)">暂无文档</div>';
  g('fb').textContent=af?getFn(af):'全部文档';g('kb').style.display=(af&&af!=='uncategorized')?'inline-block':'none';
}

function ni(id,name,icon,sel){return '<div class="nav-item'+(sel?' sel':'')+'" data-action="sf" data-id="'+esc(id)+'">'+icon+' '+esc(name)+'</div>'}
function di(id,title,sel){return '<div class="nav-item'+(sel?' sel':'')+'" data-action="sd" data-id="'+esc(id)+'" style="padding-left:20px;font-size:12px"><span style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;flex:1">'+esc(title)+'</span><span data-action="delDoc" data-id="'+esc(id)+'" style="cursor:pointer;opacity:.4;font-size:14px;padding:0 4px">✕</span></div>'}

// ====== ACTIONS ======
async function sf(id){if(af&&af!==id){saveChat()};af=id===af?'':id;ad='';hist=[];await loadAll();await loadChat();renderChat();suggestQuestions();if(af&&af!=='uncategorized')preloadKnowledge()}
function sd(id){ad=id===ad?'':id;renderSidebar()}
async function createFolder(){var n=g('nfn').value.trim();if(!n)return;await api('/api/folders',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({name:n})});g('nfn').value='';toast('已创建：'+n);await loadAll()}
async function delDoc(id){if(!confirm('删除？'))return;await api('/api/docs/'+id,{method:'DELETE'});if(ad===id)ad='';await loadAll()}

async function upload(inp){var fs=inp.files;if(!fs.length)return;for(var i=0;i<fs.length;i++){var f=fs[i],fd=new FormData();fd.append('file',f);if(af&&af!=='uncategorized')fd.append('folder_id',af);try{var r=await api('/api/upload',{method:'POST',body:fd});toast('✅ '+f.name+' · '+r.doc.chunks+' 段落')}catch(e){toast('❌ '+e.message)}}inp.value='';await loadAll()}

// ====== CHAT ======
function renderChat(){var c=g('cm');if(!hist.length){c.innerHTML='<div class="empty"><div class="empty-icon">📖</div><h2>上传文档，开始探索</h2><p>支持 PDF、DOCX、TXT、Markdown 等格式</p><div class="suggest-chips" id="sg"></div></div>';return}var h='';hist.forEach(function(m){if(m.role==='user')h+='<div class="msg user"><div class="bubble">'+esc(m.content)+'</div></div>';else{var txt=typeof marked!=='undefined'?marked.parse(m.content):m.content;txt=txt.replace(/\[引用(\d+)\]/g,'<sup class="cite" onclick="event.stopPropagation();showCitation(parseInt($1))">[$1]</sup>');h+='<div class="msg assistant"><div class="bubble">'+txt+'</div>';if(m.citations&&m.citations.length>1){var titles=m.citations.map(function(c){return c.title});var uniq=titles.filter(function(v,i,a){return a.indexOf(v)===i});if(uniq.length>1)h+='<span class="multi-doc-hint">📚 综合了 '+uniq.length+' 份文档</span>'}}});c.innerHTML=h;c.scrollTop=c.scrollHeight}

async function ask(){var q=g('qi').value.trim();if(!q)return;hist.push({role:'user',content:q});g('qi').value='';renderChat();saveChat();g('cm').innerHTML+='<div class="msg assistant" id="stream-msg"><div class="bubble"><span class="stream-cursor">▊</span></div></div>';g('cm').scrollTop=g('cm').scrollHeight;var citations=null,sources=null,fullText='';try{var resp=await fetch(API+'/api/ask/stream',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({query:q,doc_id:ad||undefined,folder_id:af||undefined,history:hist.slice(0,-1)})});var reader=resp.body.getReader(),decoder=new TextDecoder(),buffer='';while(true){var r2=await reader.read();if(r2.done)break;buffer+=decoder.decode(r2.value,{stream:true});var lines=buffer.split('\n');buffer=lines.pop()||'';for(var i=0;i<lines.length;i++){var line=lines[i];if(!line.startsWith('data: '))continue;try{var event=JSON.parse(line.slice(6))}catch(e){continue}if(event.type==='citations')citations=event.data;else if(event.type==='sources')sources=event.data;else if(event.type==='text'){fullText+=event.data;var el=document.getElementById('stream-msg');if(el){var txt=typeof marked!=='undefined'?marked.parse(fullText):fullText;txt=txt.replace(/\[引用(\d+)\]/g,'<sup class="cite" onclick="event.stopPropagation();showCitation(parseInt($1))">[$1]</sup>');el.querySelector('.bubble').innerHTML=txt+'<span class="stream-cursor">▊</span>';g('cm').scrollTop=g('cm').scrollHeight}}else if(event.type==='error'){fullText='❌ '+event.data;break}else if(event.type==='done'){break}}}}catch(e){fullText='❌ '+e.message}var el=document.getElementById('stream-msg');if(el){var txt=typeof marked!=='undefined'?marked.parse(fullText||'生成失败'):(fullText||'生成失败');txt=txt.replace(/\[引用(\d+)\]/g,'<sup class="cite" onclick="event.stopPropagation();showCitation(parseInt($1))">[$1]</sup>');el.querySelector('.bubble').innerHTML=txt;el.removeAttribute('id');if(citations&&citations.length>1){var titles=citations.map(function(c){return c.title});var uniq=titles.filter(function(v,i,a){return a.indexOf(v)===i});if(uniq.length>1)g('cm').innerHTML+='<span class="multi-doc-hint" style="display:inline-block;margin-top:6px">📚 综合了 '+uniq.length+' 份文档</span>'}}hist.push({role:'assistant',content:fullText,citations:citations||[],sources:sources||[]});saveChat()}

// ====== PODCAST ======
function updatePodSelect(){var s=g('pdoc'),h='<option value="">全部文档</option>';docs.forEach(function(d){h+='<option value="'+d.id+'">'+esc(d.title)+'</option>'});s.innerHTML=h}
async function genPodcast(){var did=g('pdoc').value,topic=g('ptopic').value.trim();g('pv').innerHTML='<div class="empty"><div class="empty-icon">🎤</div><h2>生成中…</h2><p>AI 正在撰写播客脚本，约需 30-60 秒</p></div>';try{var r=await api('/api/podcast',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({doc_id:did||undefined,topic:topic||undefined})});g('pv').innerHTML='<div class="script">'+marked.parse(r.script||'生成失败')+'</div>';toast('✅ 播客脚本已生成')}catch(e){g('pv').innerHTML='<div class="empty"><div class="empty-icon">❌</div><h2>生成失败</h2><p>'+e.message+'</p></div>'}}

// ====== KNOWLEDGE ======
var kmCache={},kmLoading=false;
async function preloadKnowledge(){if(kmLoading||kmCache[af])return;kmLoading=true;g('kb').textContent='⏳';try{var r=await api('/api/folders/'+af+'/knowledge',{method:'POST',headers:{'Content-Type':'application/json'}});kmCache[af]=r;g('kb').textContent='📊'}catch(e){g('kb').textContent='📊'}finally{kmLoading=false}}
async function openKnowledge(){if(!af||af==='uncategorized')return;g('mbg').classList.add('open');g('mtitle').textContent='📊 '+getFn(af)+' · 知识梳理';if(kmCache[af]){switchKm('summary')}else{g('mbody').innerHTML='<div style="text-align:center;padding:40px;color:var(--text3)">⏳ 分析中…</div>';switchKm('summary');try{var r=await api('/api/folders/'+af+'/knowledge',{method:'POST',headers:{'Content-Type':'application/json'}});kmCache[af]=r;switchKm('summary')}catch(e){g('mbody').innerHTML='<p style="color:#e53e3e">❌ '+e.message+'</p>'}}}
function switchKm(t){document.querySelectorAll('.modal-tab').forEach(function(tab){tab.classList.toggle('active',tab.getAttribute('data-km')===t)});var kd=kmCache[af];if(!kd){g('mbody').innerHTML='<p>加载中…</p>';return}var d='';if(t==='summary')d=kd.summary||'暂无总结';else if(t==='mindmap')d=kd.mindmap||'暂无思维导图';else if(t==='learning')d=kd.learning_path||'暂无学习路径';g('mbody').innerHTML='<div class="modal-panel active">'+marked.parse(d)+'</div>'}
function closeModal(){g('mbg').classList.remove('open')}

// ====== DARK MODE ======
function toggleDark(){
  var isDark=document.body.classList.toggle('dark');
  g('dt').textContent=isDark?'☀️':'🌙';
  localStorage.setItem('nb-dark',isDark?'1':'0')
}
function initDark(){
  if(localStorage.getItem('nb-dark')==='1'||(window.matchMedia&&window.matchMedia('(prefers-color-scheme:dark)').matches&&!localStorage.getItem('nb-dark'))){
    document.body.classList.add('dark');g('dt').textContent='☀️'
  }
}

// ====== CHAT PERSISTENCE ======
function _chatKey(){return af||'_all'}
async function saveChat(){
  if(!hist.length)return;
  try{await api('/api/chat/'+_chatKey(),{method:'PUT',headers:{'Content-Type':'application/json'},body:JSON.stringify({history:hist})})}catch(e){}
}
async function loadChat(){
  try{var r=await api('/api/chat/'+_chatKey());hist=r.history||[]}catch(e){hist=[]}
}
function clearChat(){
  if(!confirm('清空当前对话？'))return;
  hist=[];renderChat();saveChat();
  api('/api/chat/'+_chatKey(),{method:'DELETE'}).catch(function(){})
}

// ====== SUGGESTED QUESTIONS ======
async function suggestQuestions(){
  var el=g('sg');if(!el)return;
  el.innerHTML='<span style="font-size:11px;color:var(--text3)">⏳</span>';
  try{
    var r=await api('/api/suggest',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({doc_id:ad||undefined,folder_id:af||undefined})});
    var qs=r.questions||[];
    el.innerHTML=qs.map(function(q,i){return '<span class="suggest-chip" onclick="askSuggested(\''+q.replace(/'/g,"\\'")+'\')">'+esc(q)+'</span>'}).join('')
  }catch(e){el.innerHTML=''}
}
function askSuggested(q){
  g('qi').value=q;ask()
}

// ====== INIT ======
window.onerror=function(m,s,l,c,e){
  document.body.innerHTML='<div style="padding:20px;color:red;font-family:monospace"><h2>JS Error</h2><pre>'+m+'<br>'+s+':'+l+'</pre></div>';
};
function initSourcePanel(){
  var s=g('srcDoc'),h='<option value="">选择文档…</option>';
  docs.forEach(function(d){h+='<option value="'+d.id+'">'+esc(d.title)+'</option>'});
  s.innerHTML=h;
}
async function loadSource(id){
  if(!id){g('sc').innerHTML='<div class="empty"><div class="empty-icon">📄</div><h2>选择文档查看原文</h2></div>';return}
  g('sc').innerHTML='<div style="text-align:center;padding:40px;color:var(--text3)">⏳ 加载中…</div>';
  try{
    var r=await api('/api/docs/'+id+'/fulltext');
    var chunks=r.chunks||[];
    var h='<h3 style="margin-bottom:12px;font-size:15px">'+esc(r.title||'')+'</h3>';
    chunks.forEach(function(c,i){
      h+='<div class="source-chunk"><span class="chunk-idx">#'+(i+1)+'</span>'+esc(c)+'</div>';
    });
    g('sc').innerHTML=h||'<div class="empty"><p>无内容</p></div>';
  }catch(e){
    g('sc').innerHTML='<p style="color:#e53e3e">❌ '+e.message+'</p>';
  }
}

initDark();
</script>
</body>
</html>